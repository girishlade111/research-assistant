# ── ResAgent Environment Variables ─────────────────────────────
# Add your API keys below. This file is ignored by Git (.gitignore).
# Copy this file to .env.local for local development if needed.

# NVIDIA NIM API Key — used for NVIDIA-hosted models (fast, balanced, reasoning)
# Get yours at: https://build.nvidia.com
NVIDIA_API_KEY=******************

# OpenRouter API Key — fallback provider for model resilience
# Get yours at: https://openrouter.ai
OPENROUTER_API_KEY=**********************
